---
// VisaApplicationExplainer.astro
const { lang = 'es' } = Astro.props;

const content = {
  es: {
    heroTitle: "Aplicaciones de Visa para Estados Unidos",
    heroSubtitle: "Te ayudamos a entender mejor tus opciones, organizar tus documentos y prepararte con mayor claridad para tu proceso de visa en Estados Unidos.",
    requestOrient: "Solicitar orientación",
    whatsappLink: "Hablar por WhatsApp",
    scheduleConsult: "Agendar consulta",
    badgeAccent: "Orientación USCIS y Consular",
    
    // Intro
    introTitle: "Orientación Clara y Profesional",
    introText: "Sabemos que iniciar una aplicación de visa puede generar muchas dudas: qué formulario usar, qué documentos preparar, cómo organizar la información y qué pasos seguir. Por eso, ofrecemos orientación profesional para ayudarte a comprender mejor el proceso y prepararte de forma ordenada. Nuestro objetivo es acompañarte con información clara, atención personalizada y una guía sencilla para que puedas avanzar con mayor seguridad.",
    disclaimerTitle: "Nota importante de responsabilidad",
    disclaimerText: "No somos abogados de inmigración ni proveemos representación legal en cortes. No podemos ni garantizamos la aprobación de visas, ya que esa es decisión exclusiva de las autoridades consulares de EE.UU. Nuestro servicio es de orientación informativa, organización y revisión de documentos.",

    // Subservices
    subservicesTitle: "Subservicios de Orientación Disponibles",
    subservices: [
      {
        title: "Visa de Turismo",
        desc: "Orientación para personas que desean viajar a Estados Unidos por turismo, visita familiar, eventos o motivos temporales."
      },
      {
        title: "Renovación de Visa",
        desc: "Acompañamiento para quienes necesitan renovar una visa existente y desean preparar su documentación de forma organizada."
      },
      {
        title: "Visa de Estudiante",
        desc: "Orientación para personas interesadas en estudiar en Estados Unidos y conocer los pasos generales del proceso."
      },
      {
        title: "Visa de Trabajo",
        desc: "Información y orientación general para personas que desean entender opciones relacionadas con visas laborales."
      },
      {
        title: "Visa Familiar",
        desc: "Orientación para procesos relacionados con familiares, reunificación y preparación de documentos."
      },
      {
        title: "Permisos de Trabajo",
        desc: "Ayuda para entender requisitos generales, preparación de formularios y organización de documentos relacionados con permisos de trabajo."
      },
      {
        title: "Ajuste de Estatus",
        desc: "Orientación general para personas que desean entender mejor el proceso de ajuste de estatus dentro de Estados Unidos."
      },
      {
        title: "Preparación de Formularios",
        desc: "Asistencia en la preparación, revisión y organización de formularios migratorios, según la información proporcionada por el cliente."
      },
      {
        title: "Orientación Migratoria",
        desc: "Consulta personalizada para revisar el caso, explicar opciones generales y orientar al cliente sobre los próximos pasos."
      }
    ],
    requestBtn: "Solicitar información",

    // Why Us
    whyTitle: "¿Por qué recibir orientación con nosotros?",
    benefits: [
      "Explicamos el proceso en lenguaje claro y sencillo",
      "Ayudamos a organizar documentos importantes",
      "Brindamos atención personalizada",
      "Orientamos a la comunidad latina en español",
      "Revisamos la información con cuidado",
      "Acompañamos paso a paso de forma profesional",
      "Evitamos confusión y desorganización durante el proceso",
      "Ofrecemos un servicio humano, responsable y confiable"
    ],

    // Process
    processTitle: "Cómo funciona el proceso",
    steps: [
      {
        num: "Paso 1",
        title: "Consulta inicial",
        desc: "Escuchamos tu situación y entendemos qué tipo de orientación necesitas."
      },
      {
        num: "Paso 2",
        title: "Revisión de información",
        desc: "Revisamos la información y documentos que tienes disponibles."
      },
      {
        num: "Paso 3",
        title: "Organización del proceso",
        desc: "Te ayudamos a identificar qué documentos pueden ser necesarios y cómo ordenarlos."
      },
      {
        num: "Paso 4",
        title: "Preparación de formularios",
        desc: "Te orientamos en la preparación de formularios y datos importantes."
      },
      {
        num: "Paso 5",
        title: "Acompañamiento y seguimiento",
        desc: "Te guiamos durante el proceso para que tengas mayor claridad en cada etapa."
      }
    ],

    // Required Documents
    docsTitle: "Documentos que podrías necesitar",
    docsText: "Los documentos pueden variar según el tipo de visa, la situación personal y los requisitos aplicables. Por eso, recomendamos una consulta personalizada antes de iniciar el proceso.",
    docItems: [
      "Pasaporte vigente",
      "Identificación personal",
      "Fotografías tipo pasaporte, si aplica",
      "Información familiar",
      "Información laboral o académica",
      "Historial de viajes",
      "Documentos financieros",
      "Cartas o soportes relacionados al motivo de viaje",
      "Documentos migratorios anteriores, si aplica"
    ],

    // Gallery
    galleryTitle: "Galería de Preparación e Información",
    gallery: [
      {
        img: "/assets/images/project_visa_documents.png",
        alt: "Preparación de documentos migratorios en Newark New Jersey"
      },
      {
        img: "/assets/images/project_visa_consultation.png",
        alt: "Orientación para aplicaciones de visa en Estados Unidos"
      },
      {
        img: "/assets/images/project_visa_passport.png",
        alt: "Asesoría para visa de turismo en Estados Unidos"
      }
    ],

    // FAQ
    faqTitle: "Preguntas Frecuentes sobre Visas",
    faqs: [
      {
        q: "¿Ustedes garantizan la aprobación de una visa?",
        a: "No. Ningún servicio puede garantizar la aprobación de una visa. Nuestro trabajo es orientarte, ayudarte a organizar tu información y prepararte de manera clara y profesional."
      },
      {
        q: "¿Me pueden ayudar con la renovación de visa?",
        a: "Sí. Podemos orientarte en la organización de documentos y preparación general para el proceso de renovación."
      },
      {
        q: "¿Puedo recibir orientación si no sé qué visa necesito?",
        a: "Sí. Podemos revisar tu situación general y explicarte opciones comunes para que entiendas mejor qué camino podría aplicar a tu caso."
      },
      {
        q: "¿Ayudan con formularios migratorios?",
        a: "Sí. Podemos ayudarte con preparación, revisión y organización de formularios según la información que proporciones."
      },
      {
        q: "¿Atienden en español?",
        a: "Sí. Ofrecemos orientación en español para la comunidad latina."
      },
      {
        q: "¿Dónde están ubicados?",
        a: "La atención principal está enfocada en Newark, New Jersey, y también podemos orientar a personas de otras áreas según disponibilidad."
      },
      {
        q: "¿Puedo hacer una consulta por WhatsApp?",
        a: "Sí. Puedes comunicarte por WhatsApp para solicitar más información o agendar una consulta."
      }
    ],

    // Final CTA
    finalCtaTitle: "No empieces tu proceso con dudas",
    finalCtaText: "Recibe orientación clara, organiza tus documentos y avanza con mayor confianza de la mano de profesionales comprometidos.",
    whatsappCta: "Hablar por WhatsApp"
  },
  en: {
    heroTitle: "US Visa Applications",
    heroSubtitle: "We help you understand your options, organize your documents, and prepare clearly for your US visa process.",
    requestOrient: "Request guidance",
    whatsappLink: "Speak via WhatsApp",
    scheduleConsult: "Book consultation",
    badgeAccent: "USCIS & Consular Guidance",
    
    // Intro
    introTitle: "Clear & Professional Guidance",
    introText: "We know that starting a visa application can raise many questions: which form to use, which documents to prepare, how to organize information, and what steps to follow. That's why we offer professional guidance to help you better understand the process and prepare in an orderly manner. Our goal is to accompany you with clear information, personalized attention, and a simple guide so you can move forward with greater safety.",
    disclaimerTitle: "Important Legal Disclaimer",
    disclaimerText: "We are not immigration attorneys and do not provide legal representation in court. We cannot and do not guarantee visa approvals, as this is the sole authority of the US consular offices. Our service is informational guidance, document organization, and review.",

    // Subservices
    subservicesTitle: "Available Orientation Services",
    subservices: [
      {
        title: "Tourist Visa",
        desc: "Guidance for individuals who wish to travel to the United States for tourism, family visits, events, or temporary purposes."
      },
      {
