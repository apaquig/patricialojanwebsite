const t = content[lang] || content.es;
---

<div class="visa-application-explainer">
  <!-- Intro Hero & Disclaimer -->
  <div class="visa-intro-section card glass-card">
    <div class="badge badge-accent">{t.badgeAccent}</div>
    <h3 class="visa-section-title">{t.introTitle}</h3>
    <p class="visa-section-desc">{t.introText}</p>
    
    <div class="visa-disclaimer-box">
      <div class="disclaimer-title-row">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="disclaimer-icon"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
        <strong>{t.disclaimerTitle}</strong>
      </div>
      <p>{t.disclaimerText}</p>
    </div>
  </div>

  <!-- Subservices Cards -->
  <div class="visa-subservices-section">
    <div class="section-header text-center">
      <h3 class="custom-subtitle">{t.subservicesTitle}</h3>
    </div>

    <div class="grid grid-2 grid-3 visa-subservices-grid">
      {t.subservices.map((sub, index) => {
        const images = [
          "/assets/images/card_visa_turismo.png",
          "/assets/images/card_visa_renovacion.png",
          "/assets/images/card_visa_estudiante.png",
          "/assets/images/card_visa_trabajo.png",
          "/assets/images/card_visa_familiar.png",
          "/assets/images/card_visa_permiso_trabajo.png",
          "/assets/images/card_visa_ajuste_estatus.png",
          "/assets/images/card_visa_formularios.png",
          "/assets/images/card_visa_orientacion.png"
        ];
        const subImage = images[index];
        return (
          <div class="subservice-card card">
            <div class="subservice-image-wrapper">
              <img src={subImage} alt={sub.title} class="subservice-image" loading="lazy" />
              <span class="subservice-number">0{index + 1}</span>
            </div>
            <div class="subservice-content">
              <h4>{sub.title}</h4>
              <p>{sub.desc}</p>
              <a href="https://wa.me/19738203353" target="_blank" rel="noopener noreferrer" class="subservice-link">
                {t.requestBtn}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="link-arrow"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Why Receive Orientation -->
  <div class="visa-benefits-section card glass-card">
    <h3 class="custom-subtitle text-center">{t.whyTitle}</h3>
    
    <div class="grid grid-2 benefits-grid">
      {t.benefits.map((benefit) => (
        <div class="benefit-item">
          <div class="benefit-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="check-icon"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <span>{benefit}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- How It Works (Process) -->
  <div class="visa-process-section">
    <h3 class="custom-subtitle text-center" style="margin-bottom: 35px;">{t.processTitle}</h3>
    
    <div class="process-timeline">
      {t.steps.map((step, index) => (
        <div class="process-step-item">
          <div class="step-badge">{index + 1}</div>
          <div class="step-card card">
            <h4>{step.title}</h4>
            <p>{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Required Documents -->
  <div class="visa-docs-section card glass-card">
    <div class="docs-header">
      <h3 class="custom-subtitle">{t.docsTitle}</h3>
