      },
      {
        title: "Orientação Imigratória",
        desc: "Consulta personalizada para avaliar a situação, esclarecer caminhos gerais e direcionar o cliente sobre as próximas fases."
      }
    ],
    requestBtn: "Solicitar informações",

    // Why Us
    whyTitle: "Por que obter orientação conosco?",
    benefits: [
      "Explicamos o processo em linguagem simples e clara",
      "Ajudamos a organizar documentos importantes",
      "Oferecemos atendimento personalizado",
      "Orientamos a comunidade latina em espanhol/português",
      "Analisamos as informações com rigor",
      "Acompanhamos você passo a passo profissionalmente",
      "Evitamos confusões e atrasos durante a montagem do processo",
      "Prestamos um serviço humanizado, responsável e de confiança"
    ],

    // Process
    processTitle: "Como funciona o processo",
    steps: [
      {
        num: "Passo 1",
        title: "Consulta inicial",
        desc: "Ouvimos seu caso para entender quais necessidades de orientação você possui."
      },
      {
        num: "Passo 2",
        title: "Revisão de dados",
        desc: "Analisamos as informações e documentos que você já tem em mãos."
      },
