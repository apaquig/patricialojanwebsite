---
// FAQ.astro
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faqList: FAQItem[];
}

const { faqList } = Astro.props;
---

<div class="faq-accordion-container">
  {faqList.map((item, index) => (
    <details class="faq-item" name="faq-group">
      <summary class="faq-question">
        <span>{item.question}</span>
        <span class="faq-icon-wrapper">
          <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </span>
      </summary>
      <div class="faq-answer">
        <p>{item.answer}</p>
      </div>
    </details>
  ))}
</div>

<style>
  .faq-accordion-container {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .faq-item {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-sm);
    transition: border-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .faq-item[open] {
    border-color: var(--accent-color);
    box-shadow: var(--shadow-md);
  }

  .faq-question {
    list-style: none; /* Hide default summary arrow */
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    font-family: var(--font-family-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--primary-color);
    cursor: pointer;
    user-select: none;
  }

  /* Webkit summary fix */
  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--bg-secondary);
    color: var(--primary-color);
    transition: background-color var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
  }

  .faq-item[open] .faq-icon-wrapper {
    background: var(--accent-color);
    color: var(--text-white);
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 24px 24px 24px;
    border-top: 1px solid var(--border-light);
    animation: slideDown var(--transition-normal) ease-out;
  }

  .faq-answer p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-top: 16px;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
