---
// LogoGrid.astro
interface Props {
  lang?: 'es' | 'en' | 'pt';
}

const { lang = 'es' } = Astro.props;

const content = {
  es: {
    subtitle: "TRABAJAMOS CON LAS COMPAÑÍAS LÍDERES DEL MERCADO",
    title: "Aseguradoras y Aliados Comerciales",
    tagCar: "Seguros de Carro",
    tagCompany: "Seguros de Compañía"
  },
  en: {
    subtitle: "WE WORK WITH THE MARKET LEADING COMPANIES",
    title: "Insurers and Business Allies",
    tagCar: "Car Insurance",
    tagCompany: "Company Insurance"
  },
  pt: {
    subtitle: "TRABALHAMOS COM AS EMPRESAS LÍDERES DO MERCADO",
    title: "Seguradoras e Parceiros Comerciais",
    tagCar: "Seguro de Carro",
    tagCompany: "Seguro Comercial"
  }
};

const t = content[lang] || content.es;
---

<div class="logo-grid-container text-center">
  <p class="logo-grid-subtitle">{t.subtitle}</p>
  <h2 class="logo-grid-title">{t.title}</h2>
  
  <div class="logo-grid">
    <!-- Progressive Card -->
    <div class="logo-card" title="Progressive Insurance">
      <span class="logo-brand progressive">Progressive</span>
      <span class="logo-service-tag">{t.tagCar}</span>
    </div>

    <!-- GEICO Card -->
    <div class="logo-card" title="GEICO Insurance">
      <span class="logo-brand geico">GEICO</span>
      <span class="logo-service-tag">{t.tagCar}</span>
    </div>

    <!-- ETHOS Card -->
    <div class="logo-card" title="ETHOS Life">
      <span class="logo-brand ethos">ETHOS</span>
      <span class="logo-service-tag">{t.tagCompany}</span>
    </div>

    <!-- Corebridge Card -->
    <div class="logo-card" title="Corebridge Financial">
      <span class="logo-brand corebridge">corebridge</span>
      <span class="logo-service-tag">{t.tagCompany}</span>
    </div>

    <!-- AuguStar Card -->
    <div class="logo-card" title="AuguStar Financial">
      <span class="logo-brand augustar">AuguStar</span>
      <span class="logo-service-tag">{t.tagCompany}</span>
    </div>
  </div>
</div>

<style>
  .logo-grid-container {
    padding: 60px 0;
  }

  .logo-grid-subtitle {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--accent-color);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .logo-grid-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary-color);
    margin-bottom: 40px;
  }

  .logo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    align-items: center;
  }

  @media (min-width: 640px) {
    .logo-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .logo-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .logo-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-sm);
    padding: 24px 16px;
    height: 100px;
    box-shadow: var(--shadow-sm);
    filter: grayscale(100%);
    opacity: 0.7;
    transition: filter var(--transition-normal), opacity var(--transition-normal), transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .logo-card:hover {
    filter: grayscale(0);
    opacity: 1;
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  /* Custom typography styled brand logos */
  .logo-brand {
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 4px;
  }

  .logo-service-tag {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Specific color themes for each logo when hovered */
  .logo-card:hover .progressive {
    color: #005A9C;
  }

  .logo-card:hover .geico {
    color: #00875A;
  }

  .logo-card:hover .ethos {
    color: #4F46E5;
  }

  .logo-card:hover .corebridge {
    color: #0284C7;
  }

  .logo-card:hover .augustar {
    color: #D4AF37;
  }
</style>
