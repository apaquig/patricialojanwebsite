</style>

<script>
  // Mobile Navigation toggle
  const toggleBtn = document.querySelector('.mobile-nav-toggle');
  const navMenu = document.querySelector('.nav-menu');
  
  if (toggleBtn && navMenu) {
    toggleBtn.addEventListener('click', () => {
      const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      toggleBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      toggleBtn.classList.toggle('active');
      navMenu.classList.toggle('active');
      document.body.style.overflow = isExpanded ? '' : 'hidden'; // Prevents scrolling on back
    });
  }

  // Mobile Accordion functionality
  const dropdownToggles = document.querySelectorAll('.dropdown-toggle');
  const nestedToggles = document.querySelectorAll('.dropdown-link-nested');

  if (window.innerWidth < 1024) {
    // Top-level services toggle
    dropdownToggles.forEach(toggle => {
      toggle.addEventListener('click', (e) => {
        // Only run toggle logic if it's not the language switcher button
        if (toggle.closest('.lang-selector-desktop')) return;
        
        e.preventDefault();
        const menu = toggle.nextElementSibling;
        if (menu) {
          menu.classList.toggle('active');
          const chevron = toggle.querySelector('.chevron-icon');
          if (chevron) {
            chevron.style.transform = menu.classList.contains('active') ? 'rotate(180deg)' : '';
          }
        }
      });
    });

    // Second-level items toggle
    nestedToggles.forEach(toggle => {
      toggle.addEventListener('click', (e) => {
        e.preventDefault();
        const menu = toggle.nextElementSibling;
        if (menu) {
          menu.classList.toggle('active');
          const chevron = toggle.querySelector('.chevron-icon-right');
          if (chevron) {
            chevron.style.transform = menu.classList.contains('active') ? 'rotate(90deg)' : '';
          }
        }
      });
    });
  }

  // Client-side Language Selection and Redirection
  document.querySelectorAll('[data-lang-change]').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const targetLang = el.getAttribute('data-lang-change');
      
      // Save language preference in localStorage
      localStorage.setItem('preferred-language', targetLang);
      
      // Detect clean path (strip prefix /es, /en, or /pt)
      const path = window.location.pathname;
      const hasLangPrefix = /^\/(es|en|pt)(\/|$)/.test(path);
      const cleanPath = hasLangPrefix ? path.replace(/^\/(es|en|pt)/, '') : path;
      
      // Redirect to the same clean path with the new language prefix
      window.location.href = `/${targetLang}${cleanPath || '/'}`;
    });
  });
</script>
