---
import MainLayout from '../../../layouts/MainLayout.astro';
import { blogPosts } from '../../../data/blog';
import { translations } from '../../../data/translations';

export async function getStaticPaths() {
  const langs = ['es', 'en', 'pt'];
  const paths = [];
  
  langs.forEach(lang => {
    const list = blogPosts[lang] || blogPosts.es;
    list.forEach(post => {
      paths.push({
        params: { lang, slug: post.slug },
        props: { post, lang }
      });
    });
  });
  
  return paths;
}

const { post, lang = 'es' } = Astro.props;
const t = translations[lang] || translations.es;

const getCategoryGradient = (cat: string) => {
  const c = cat.toLowerCase();
  if (c.includes('retiro') || c.includes('retirement') || c.includes('aposentadoria')) {
    return 'linear-gradient(135deg, #0b2240 0%, #b8901c 100%)';
  } else if (c.includes('seguro') || c.includes('insurance')) {
    return 'linear-gradient(135deg, #0b2240 0%, #1a56db 100%)';
  } else if (c.includes('crédito') || c.includes('credit')) {
    return 'linear-gradient(135deg, #1e293b 0%, #0b2240 100%)';
  } else if (c.includes('trámite') || c.includes('procedure') || c.includes('procedimento')) {
    return 'linear-gradient(135deg, #0f172a 0%, #163a66 100%)';
  } else {
    return 'linear-gradient(135deg, #0b2240 0%, #475569 100%)';
  }
};

const readTimeSuffix = {
  es: "de lectura",
  en: "read",
  pt: "de leitura"
};

const ctaTitle = {
  es: "¿Quieres saber cómo se aplica esto a tu caso particular?",
  en: "Want to know how this applies to your specific case?",
  pt: "Quer saber como isso se aplica ao seu caso específico?"
};

const ctaDesc = {
  es: "No dejes tus dudas al azar. Patricia Lojan te asesora directamente, ayudándote a tomar la decisión más segura para proteger tu dinero y a tu familia.",
  en: "Don't leave your doubts to chance. Patricia Lojan advises you directly, helping you make the safest decision to protect your money and your family.",
  pt: "Não deixe suas dúvidas ao acaso. Patricia Lojan assessora você diretamente, ajudando a tomar a decisão mais segura para proteger seu dinheiro e sua família."
};

const ctaBtn = {
  es: "Agendar consulta gratuita",
  en: "Book free consultation",
  pt: "Agendar consulta gratuita"
};

const ctaWhatsapp = {
  es: "Preguntar por WhatsApp",
  en: "Ask on WhatsApp",
  pt: "Perguntar no WhatsApp"
};
---

<MainLayout
  title={`${post.title} | Blog | Enterprises Capital LLC`}
  description={post.excerpt}
  lang={lang}
>
  <!-- Article Header Banner -->
  <header class="article-hero" style={`background: ${getCategoryGradient(post.category)}`}>
    <div class="article-hero-overlay"></div>
    <div class="container article-hero-container">
      <div class="article-hero-content">
        <a href={`/${lang}/blog`} class="back-to-blog">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          {t.blog.backToBlog}
        </a>
        <span class="article-badge">{post.category}</span>
        <h1 class="article-title">{post.title}</h1>
        <div class="article-meta">
          <span class="article-date">{post.date}</span>
          <span class="meta-separator">&bull;</span>
          <span class="article-author">{t.blog.authorBadge}</span>
          <span class="meta-separator">&bull;</span>
          <span class="article-readtime">{post.readTime} {readTimeSuffix[lang] || readTimeSuffix.es}</span>
        </div>
      </div>
    </div>
  </header>

  <!-- Article Body -->
  <section class="section article-section">
    <div class="container article-body-container">
      <article class="article-rich-text" set:html={post.content} />
      
      <!-- Inside Article CTA -->
      <div class="article-footer-cta card glass-card">
        <h3>{ctaTitle[lang] || ctaTitle.es}</h3>
        <p>
          {ctaDesc[lang] || ctaDesc.es}
        </p>
        <div class="cta-actions">
          <a href={`/${lang}/contacto`} class="btn btn-primary">{ctaBtn[lang] || ctaBtn.es}</a>
          <a href={`https://wa.me/19738203353?text=Hola%20Patricia,%20leí%20tu%20artículo%20sobre%20${encodeURIComponent(post.title)}%20y%20me%20gustaría%20saber%20más.`} target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 0 0 1.333 4.982L2 22l5.202-1.362a9.927 9.927 0 0 0 4.81 1.238h.005c5.507 0 9.99-4.478 9.99-9.984C22.007 6.478 17.518 2 12.012 2zm6.09 14.415c-.25.703-1.47 1.28-2.01 1.37-.48.08-.94.09-2.93-.73a11.83 11.83 0 0 1-5.11-4.49c-.77-1.04-1.23-2.26-1.23-3.51 0-1.42.75-2.11 1.02-2.38.21-.21.46-.26.65-.26h.46c.15 0 .35.01.5.38.17.41.6 1.48.65 1.58.05.11.09.23.01.38-.08.15-.15.25-.26.38-.11.13-.23.29-.33.39-.11.11-.23.23-.1.46.26.46.86 1.47 1.63 2.15.99.88 1.83 1.15 2.09 1.28.26.13.41.11.56-.05.15-.16.65-.75.82-1.01.17-.26.35-.22.59-.13.24.09 1.54.73 1.8.86.26.13.43.2.5.31.06.11.06.66-.19 1.36z"/></svg>
            {ctaWhatsapp[lang] || ctaWhatsapp.es}
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Article Hero */
  .article-hero {
    position: relative;
    padding: 180px 0 80px 0;
    color: var(--text-white);
    overflow: hidden;
  }

  .article-hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 70% 30%, rgba(255, 255, 255, 0.05) 0%, rgba(11, 34, 64, 0.95) 70%, var(--primary-dark) 100%);
  }

  .article-hero-container {
    position: relative;
    z-index: 2;
  }

  .article-hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .back-to-blog {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-family-heading);
    font-weight: 600;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 24px;
    transition: color var(--transition-fast);
  }

  .back-to-blog:hover {
    color: var(--text-white);
  }

  .back-to-blog svg {
    transition: transform var(--transition-fast);
  }

  .back-to-blog:hover svg {
    transform: translateX(-4px);
  }

  .article-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--gold-color);
    color: var(--primary-dark);
    padding: 4px 12px;
    border-radius: var(--border-radius-sm);
    margin-bottom: 20px;
  }

  .article-title {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--text-white);
    line-height: 1.25;
    margin-bottom: 20px;
  }

  @media (min-width: 768px) {
    .article-title {
      font-size: 2.75rem;
    }
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.75);
    font-weight: 500;
  }

  .meta-separator {
    color: rgba(255, 255, 255, 0.3);
  }

  /* Article Body spacing */
  .article-section {
    padding-top: 60px;
  }

  .article-body-container {
    max-width: 800px;
    margin: 0 auto;
  }

  /* Rich Text Elements Styles */
  .article-rich-text :global(p) {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .article-rich-text :global(h2) {
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 48px;
    margin-bottom: 16px;
    color: var(--primary-color);
  }

  .article-rich-text :global(ul) {
    margin-bottom: 24px;
    padding-left: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .article-rich-text :global(li) {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .article-rich-text :global(blockquote) {
    margin: 40px 0;
    padding: 24px 30px;
    border-left: 4px solid var(--gold-color);
    background: var(--bg-secondary);
    border-radius: 0 var(--border-radius-sm) var(--border-radius-sm) 0;
    font-family: var(--font-family-heading);
    font-size: 1.25rem;
    font-style: italic;
    font-weight: 500;
    color: var(--primary-color);
    line-height: 1.5;
  }

  /* Footer CTA Inside Article */
  .article-footer-cta {
    margin-top: 60px;
    padding: 40px;
    border-color: rgba(11, 34, 64, 0.1);
  }

  .article-footer-cta h3 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .article-footer-cta p {
    font-size: 1.05rem;
    color: var(--text-secondary);
    margin-bottom: 24px;
    line-height: 1.6;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  @media (max-width: 640px) {
    .cta-actions {
      flex-direction: column;
      width: 100%;
    }
    
    .cta-actions .btn {
      width: 100%;
    }
  }
</style>
