---
import MainLayout from '../../layouts/MainLayout.astro';
import Hero from '../../components/Hero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import LogoGrid from '../../components/LogoGrid.astro';
import FAQ from '../../components/FAQ.astro';
import { services } from '../../data/services';
import { faqs } from '../../data/faqs';
import { translations } from '../../data/translations';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
    { params: { lang: 'pt' } }
  ];
}

const { lang = 'es' } = Astro.params;
const t = translations[lang] || translations.es;
const indexT = t.index;

const featuredServiceIds = [
  "notaria-publica",
  "tramites-migratorios",
  "seguros-vida",
  "seguros-carro",
  "anualidades-indexadas",
  "reparacion-credito",
  "contabilidad-finanzas",
  "asesoria-estrategica-empresarial"
];

const featuredServices = (services[lang] || services.es).filter(service => featuredServiceIds.includes(service.id));
const generalFaqs = (faqs[lang] || faqs.es)[0]?.questions || [];
---

<MainLayout 
  title={t.meta.defaultTitle}
  description={t.meta.defaultDesc}
  lang={lang}
>
  <!-- Hero Section -->
  <Hero lang={lang} />

  <!-- Featured Services Grid -->
  <section class="section">
    <div class="container">
      <div class="section-header text-center">
        <span class="badge badge-primary">{indexT.servicesBadge}</span>
        <h2 class="section-title">{indexT.servicesTitle}</h2>
        <p class="section-desc">{indexT.servicesDesc}</p>
      </div>

      <div class="grid grid-2 grid-3 grid-4">
        {featuredServices.map(service => (
          <ServiceCard 
            id={service.id}
            title={service.title}
            shortDescription={service.shortDescription}
            href={`/${lang}/servicios/${service.id}`}
            image={service.image}
            category={service.category}
            lang={lang}
          />
        ))}
      </div>

      <div class="services-action text-center">
        <a href={`/${lang}/servicios`} class="btn btn-primary btn-large">{indexT.viewAllServices}</a>
      </div>
    </div>
  </section>

  <!-- Why Us Section -->
  <section class="section section-secondary">
    <div class="container grid grid-2 why-us-grid">
      <div class="why-us-content">
        <span class="badge badge-gold">{indexT.whyUsBadge}</span>
        <h2 class="why-us-title">{indexT.whyUsTitle}</h2>
        <p class="why-us-desc">{indexT.whyUsDesc}</p>
        
        <ul class="why-us-list">
          <li>
            <div class="list-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <div>
              <strong>{indexT.whyUsItem1Title}</strong> {indexT.whyUsItem1Text}
            </div>
          </li>
          <li>
            <div class="list-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <div>
              <strong>{indexT.whyUsItem2Title}</strong> {indexT.whyUsItem2Text}
            </div>
          </li>
          <li>
            <div class="list-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <div>
              <strong>{indexT.whyUsItem3Title}</strong> {indexT.whyUsItem3Text}
            </div>
          </li>
          <li>
            <div class="list-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <div>
              <strong>{indexT.whyUsItem4Title}</strong> {indexT.whyUsItem4Text}
            </div>
          </li>
        </ul>
      </div>

      <!-- Quick Profile Card -->
      <div class="quick-profile-card card glass-card">
        <div class="profile-image-container">
          <!-- Note: Astro 6 uses static imports or assets directory for local images. We reference it from public/src path securely. -->
          <img src="/assets/images/patricia-lojan.jpg" alt="Patricia Lojan" class="profile-img" />
        </div>
        <div class="profile-card-content text-center">
          <h3 class="profile-name">Patricia Lojan</h3>
          <p class="profile-role">{indexT.profileRole}</p>
          <p class="profile-quote">
            {indexT.profileQuote}
          </p>
          <a href={`/${lang}/perfil-profesional`} class="btn btn-secondary">{indexT.profileTrajectory}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Alliance Logo Grid -->
  <section class="section">
    <div class="container">
      <LogoGrid lang={lang} />
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section section-secondary">
    <div class="container">
      <div class="section-header text-center">
        <span class="badge badge-primary">{indexT.faqBadge}</span>
        <h2 class="section-title">{indexT.faqTitle}</h2>
        <p class="section-desc">{indexT.faqDesc}</p>
      </div>

      <FAQ faqList={generalFaqs} />
    </div>
  </section>

  <!-- Call To Action Section -->
  <section class="section cta-section text-center">
    <div class="container cta-container card glass-card">
      <h2 class="cta-title">{t.cta.title}</h2>
      <p class="cta-desc">{t.cta.desc}</p>
      <div class="cta-actions">
        <a href={`/${lang}/contacto`} class="btn btn-primary btn-large">{t.cta.bookBtn}</a>
        <a href="https://wa.me/19738203353" target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp btn-large">
          <svg class="btn-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 0 0 1.333 4.982L2 22l5.202-1.362a9.927 9.927 0 0 0 4.81 1.238h.005c5.507 0 9.99-4.478 9.99-9.984C22.007 6.478 17.518 2 12.012 2zm6.09 14.415c-.25.703-1.47 1.28-2.01 1.37-.48.08-.94.09-2.93-.73a11.83 11.83 0 0 1-5.11-4.49c-.77-1.04-1.23-2.26-1.23-3.51 0-1.42.75-2.11 1.02-2.38.21-.21.46-.26.65-.26h.46c.15 0 .35.01.5.38.17.41.6 1.48.65 1.58.05.11.09.23.01.38-.08.15-.15.25-.26.38-.11.13-.23.29-.33.39-.11.11-.23.23-.1.46.26.46.86 1.47 1.63 2.15.99.88 1.83 1.15 2.09 1.28.26.13.41.11.56-.05.15-.16.65-.75.82-1.01.17-.26.35-.22.59-.13.24.09 1.54.73 1.8.86.26.13.43.2.5.31.06.11.06.66-.19 1.36z"/></svg>
          {t.cta.whatsappBtn}
        </a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Section Headers */
  .section-header {
    max-width: 700px;
    margin: 0 auto 60px auto;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 700;
    margin-top: 16px;
    margin-bottom: 20px;
  }

  .section-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
  }

  .services-action {
    margin-top: 50px;
  }

  /* Why Us Styles */
  .why-us-grid {
    align-items: center;
  }

  .why-us-title {
    font-size: 2.25rem;
    font-weight: 700;
    margin-top: 16px;
    margin-bottom: 20px;
  }

  .why-us-desc {
    font-size: 1.1rem;
    margin-bottom: 30px;
  }

  .why-us-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .why-us-list li {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    font-size: 1rem;
    line-height: 1.5;
  }

  .list-icon {
    width: 28px;
    height: 28px;
    background: var(--accent-light);
    color: var(--accent-color);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Quick Profile Card */
  .quick-profile-card {
    padding: 0;
    overflow: hidden;
    max-width: 440px;
    margin: 0 auto;
    border-color: rgba(11, 34, 64, 0.1);
  }

  .profile-image-container {
    width: 100%;
    height: 340px;
    overflow: hidden;
  }

  .profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  .profile-card-content {
    padding: 30px;
  }

  .profile-name {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .profile-role {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  .profile-quote {
    font-style: italic;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 24px;
  }

  /* CTA Section Styling */
  .cta-section {
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
    padding: 100px 0;
    color: var(--text-white);
  }

  .cta-container {
    max-width: 960px;
    margin: 0 auto;
    padding: 60px 40px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-white);
  }

  .cta-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--text-white);
    margin-bottom: 16px;
  }

  .cta-desc {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.85);
    max-width: 700px;
    margin: 0 auto 40px auto;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
  }

  @media (max-width: 640px) {
    .cta-actions {
      flex-direction: column;
    }
    
    .cta-actions .btn {
      width: 100%;
    }
  }
</style>
